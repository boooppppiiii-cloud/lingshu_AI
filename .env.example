# 复制为 .env 并填入密钥

# 服务端口（默认 8788）
PORT=8788

# Advanced manual social account connect.
# false = customers only see one-click OAuth.
# true = implementation/admin fallback fields are visible and API-enabled.
ADVANCED_MANUAL_CONNECT_ENABLED=true

# ── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# ── PocketBase ───────────────────────────────────────────────────────────────
PB_URL=PUBLIC_BASE_URL=http://127.0.0.1:8791
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=

# ── 订阅收费墙 ───────────────────────────────────────────────────────────────
# true = studio 路由（AI 脚本/选材/封面/文案/渲染）要求登录 + 有效订阅，否则 401/402
# 留空 / false = 直通开放（默认，便于本地开发与 demo）
SUBSCRIPTION_ENFORCED=false
# 渲染授权令牌签名密钥（HMAC）。生产务必改成随机长字符串。
RENDER_TOKEN_SECRET=

# ── Cloudflare R2 ────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=e00abaf46bef781d08c4e4c9790ad68e
R2_ACCESS_KEY_ID=dca1d63b788e725be75ae166de82d8dd
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=overseas-assets
R2_PUBLIC_URL=https://pub-6786fd9ae7f0498697ae17bb0fe57689.r2.dev

# ── (可选) 千问 / DashScope ──────────────────────────────────────────────────
# OVERSEAS_LLM_BACKEND=gemini
# DASHSCOPE_API_KEY=
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── WhatsApp Business Embedded Signup ────────────────────────────────────────
# 给普通客户使用的“一键连接 WhatsApp”需要先在 Meta 后台创建 App 和 Embedded Signup 配置。
# PUBLIC_BASE_URL 必须是公网 HTTPS 域名，Meta Webhook 会回调到这个域名。
PUBLIC_BASE_URL=https://fondness-shifting-crouton.ngrok-free.dev
META_GRAPH_VERSION=v25.0
WHATSAPP_EMBEDDED_SIGNUP_APP_ID=1360394849332681
WHATSAPP_EMBEDDED_SIGNUP_APP_SECRET=fca6672b086ee3bfea6953cf79e40c8f
WHATSAPP_EMBEDDED_SIGNUP_CONFIG_ID=2511141542700937

# ── YouTube OAuth 一键连接 ────────────────────────────────────────────
# 在 Google Cloud 的 OAuth Client 里创建 Web application。
# Authorized redirect URI 必须填写：
#   ${PUBLIC_BASE_URL}/api/overseas/youtube/oauth/callback
# 本地开发可用：
#   http://127.0.0.1:8790/api/overseas/youtube/oauth/callback
YOUTUBE_OAUTH_CLIENT_ID=889565015080-jfr3m72fh6fie4pnrjhr0bjumvmgpek3.apps.googleusercontent.com
YOUTUBE_OAUTH_CLIENT_SECRET=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
# 可选：单个视频最大上传大小，默认 2048MB
YOUTUBE_MAX_UPLOAD_MB=2048

# ── TikTok / Instagram / Facebook OAuth 一键连接 ───────────────────────
# TikTok Developer app: redirect URI
#   ${PUBLIC_BASE_URL}/api/overseas/social/oauth/tiktok/callback
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Meta app 用于 Facebook Page / Instagram professional account 授权。
# redirect URI:
#   ${PUBLIC_BASE_URL}/api/overseas/social/oauth/facebook/callback
#   ${PUBLIC_BASE_URL}/api/overseas/social/oauth/instagram/callback
META_SOCIAL_APP_ID=1360394849332681
META_SOCIAL_APP_SECRET=fca6672b086ee3bfea6953cf79e40c8f
