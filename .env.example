# 复制为 .env 并填入密钥

# 服务端口（默认 8788）
PORT=8788

# ── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# 测试版保持 false；正式版接入客户自己的 Gemini Key 后设为 true
GEMINI_VIDEO_ENABLED=false
# GEMINI_VIDEO_MODEL=veo-2.0-generate-001
# GEMINI_VIDEO_TIMEOUT_MS=360000
# GEMINI_VIDEO_POLL_INTERVAL_MS=10000

# ── PocketBase ───────────────────────────────────────────────────────────────
PB_URL=http://localhost:8090
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=

# ── 订阅收费墙 ───────────────────────────────────────────────────────────────
# true = studio 路由（AI 脚本/选材/封面/文案/渲染）要求登录 + 有效订阅，否则 401/402
# 留空 / false = 直通开放（默认，便于本地开发与 demo）
SUBSCRIPTION_ENFORCED=false
# 渲染授权令牌签名密钥（HMAC）。生产务必改成随机长字符串。
RENDER_TOKEN_SECRET=

# ── Cloudflare R2 ────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=overseas-assets
R2_PUBLIC_URL=https://your-bucket.r2.dev

# ── (可选) 千问 / DashScope ──────────────────────────────────────────────────
# OVERSEAS_LLM_BACKEND=gemini
# DASHSCOPE_API_KEY=
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
