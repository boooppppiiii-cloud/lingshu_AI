# 复制为 .env 并填入密钥

# 服务端口（默认 8788）
PORT=8788

# ── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# Gemini/Veo 视频生成默认关闭；当前视频生成走 Seedance。
GEMINI_VIDEO_ENABLED=false
# GEMINI_VIDEO_MODEL=veo-2.0-generate-001
# GEMINI_VIDEO_TIMEOUT_MS=360000
# GEMINI_VIDEO_POLL_INTERVAL_MS=10000

# ── Seedance / ModelArk 视频生成 ────────────────────────────────────────────
SEEDANCE_API_KEY=
SEEDANCE_VIDEO_ENABLED=false
SEEDANCE_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
SEEDANCE_MODEL=doubao-seedance-2-0-fast-260128
# SEEDANCE_VIDEO_TIMEOUT_MS=600000
# SEEDANCE_VIDEO_POLL_INTERVAL_MS=8000

# ── PocketBase ───────────────────────────────────────────────────────────────
PB_URL=http://localhost:8090
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=

# ── 订阅收费墙 ───────────────────────────────────────────────────────────────
# true = studio 路由（AI 脚本/选材/封面/文案/渲染）要求登录 + 有效订阅，否则 401/402
# 留空 / false = 直通开放（默认，便于本地开发与 demo）
SUBSCRIPTION_ENFORCED=false
# 渲染授权令牌签名密钥（HMAC）。生产务必改成随机长字符串。
RENDER_TOKEN_SECRET=

# ── Demo / 测试账号额度 ──────────────────────────────────────────────────────
# DEMO_MODE=true 或 trial/trialing 账号生效。试用期固定 5 天。
# 注册为白名单激活模式：必须配置允许账号，否则注册接口默认拒绝。
# DEMO_ALLOWED_ACCOUNTS=test1@example.com,test2@example.com
# DEMO_DAILY_TOKEN_LIMIT=30000
# DEMO_TOTAL_TOKEN_LIMIT=30000

# ── Cloudflare R2 ────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=overseas-assets
R2_PUBLIC_URL=https://your-bucket.r2.dev

# ── (可选) 千问 / DashScope ──────────────────────────────────────────────────
# OVERSEAS_LLM_BACKEND=gemini
# DASHSCOPE_API_KEY=
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── TikTok 采集 / Apify 兜底 ─────────────────────────────────────────────────
# 本地采集优先；本地失败后使用 Apify 兜底。设为 0 可关闭对应兜底。
APIFY_TOKEN=
APIFY_TIKTOK_CRAWL_FALLBACK_ENABLED=1
APIFY_TIKTOK_VIDEO_FALLBACK_ENABLED=1
# 视频下载兜底额度：单账号每天最多 3 条，全服务器每天最多 25 条。
APIFY_TIKTOK_VIDEO_TENANT_DAILY_LIMIT=3
APIFY_TIKTOK_VIDEO_DAILY_LIMIT=25
