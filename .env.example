# 复制为 .env 并填入密钥

# 服务端口（默认 8788）
PORT=8788

# ── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# ── MiniMax 语音合成 / 真人音色克隆 ───────────────────────────────────────────
# 配置后配音会优先使用 MiniMax；普通音色走 T2A，录入真人音色会先 upload + voice_clone。
MINIMAX_API_KEY=
# 默认使用国际站 endpoint；如账号要求 GroupId，可填写下方两项。
# MINIMAX_BASE_URL=https://api.minimax.io
# MINIMAX_GROUP_ID=
# MINIMAX_GROUP_ID_PARAM=GroupId
# MINIMAX_TTS_MODEL=speech-2.8-hd
# MINIMAX_TTS_EMOTION=happy
# MINIMAX_TTS_SPEED=1
# MINIMAX_TTS_VOLUME=1
# MINIMAX_TTS_PITCH=0
# MINIMAX_TTS_SAMPLE_RATE=32000
# MINIMAX_TTS_BITRATE=128000
# 可按语种/音色覆盖系统 voice_id，例如：
# MINIMAX_VOICE_ZH_V1=Chinese (Mandarin)_Warm_Bestie
# MINIMAX_VOICE_ZH_V2=Chinese (Mandarin)_Reliable_Executive
# MINIMAX_VOICE_EN_V1=English_FriendlyPerson

# Gemini TTS 不稳定时，可配置 Piper 做跨平台本地 TTS 兜底（Windows/macOS/Linux）。
# PIPER_BIN=/absolute/path/to/piper
# PIPER_MODEL_ZH=/absolute/path/to/zh_CN-huayan-medium.onnx
# PIPER_MODEL_EN=/absolute/path/to/en_US-lessac-medium.onnx
# PIPER_MODEL_ES=/absolute/path/to/es_ES-sharvard-medium.onnx
# PIPER_MODEL_AR=/absolute/path/to/ar_JO-kareem-medium.onnx
# 也可配置默认模型；未配置对应语种时使用默认模型。
# PIPER_MODEL=/absolute/path/to/default.onnx
# 真人音色克隆：安装 Coqui TTS 后填 CLI 路径，例如 /path/to/venv/bin/tts 或 Windows 的 tts.exe。
# XTTS_BIN=/absolute/path/to/tts
# XTTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2
# XTTS_TIMEOUT_MS=120000
# Gemini/Veo 视频生成默认关闭；当前视频生成走 Seedance。
GEMINI_VIDEO_ENABLED=false
# GEMINI_VIDEO_MODEL=veo-2.0-generate-001
# GEMINI_VIDEO_TIMEOUT_MS=360000
# GEMINI_VIDEO_POLL_INTERVAL_MS=10000

# ── Seedance / ModelArk 视频生成 ────────────────────────────────────────────
SEEDANCE_API_KEY=
SEEDANCE_VIDEO_ENABLED=false
SEEDANCE_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
SEEDANCE_MODEL=doubao-seedance-2-0-fast-260128
# SEEDANCE_VIDEO_TIMEOUT_MS=600000
# SEEDANCE_VIDEO_POLL_INTERVAL_MS=8000

# ── PocketBase ───────────────────────────────────────────────────────────────
PB_URL=http://localhost:8090
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=

# ── 订阅收费墙 ───────────────────────────────────────────────────────────────
# true = studio 路由（AI 脚本/选材/封面/文案/渲染）要求登录 + 有效订阅，否则 401/402
# 留空 / false = 直通开放（默认，便于本地开发与 demo）
SUBSCRIPTION_ENFORCED=false
# 渲染授权令牌签名密钥（HMAC）。生产务必改成随机长字符串。
RENDER_TOKEN_SECRET=

# ── Demo / 测试账号额度 ──────────────────────────────────────────────────────
# DEMO_MODE=true 或 trial/trialing 账号生效。试用期固定 5 天。
# 注册为白名单激活模式：必须配置允许账号，否则注册接口默认拒绝。
# DEMO_ALLOWED_ACCOUNTS=test1@example.com,test2@example.com
# DEMO_DAILY_TOKEN_LIMIT=30000
# DEMO_TOTAL_TOKEN_LIMIT=30000

# ── 本地管理员账号 ──────────────────────────────────────────────────────────
# 仅在非生产环境启用，用于登录管理员控制台；不要与试用账号共用。
# LOCAL_ADMIN_EMAIL=admin@local.test
# LOCAL_ADMIN_PASSWORD=change-me-to-a-strong-password
# ADMIN_DASHBOARD_EMAILS=admin@local.test
# 生产环境必填，用于加密管理员后台可查看的客户初始注册密码。
# 可用 `openssl rand -base64 32` 生成。
# REGISTRATION_CREDENTIAL_KEY=

# ── Cloudflare R2 ────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=overseas-assets
R2_PUBLIC_URL=https://your-bucket.r2.dev
R2_BACKUP_PREFIX=lingshu-backups
R2_BACKUP_LOCAL_RETENTION_DAYS=7

# ── (可选) 千问 / DashScope ──────────────────────────────────────────────────
# OVERSEAS_LLM_BACKEND=gemini
# DASHSCOPE_API_KEY=
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── TikTok 采集 / Apify 兜底 ─────────────────────────────────────────────────
# 本地采集优先；本地失败后使用 Apify 兜底。设为 0 可关闭对应兜底。
APIFY_TOKEN=
# 云服务器建议保留 Apify 兜底；IG actor 采用异步 run + 轮询，超时可按网络情况调大。
# APIFY_TIMEOUT_MS=240000
# APIFY_VIDEO_TIMEOUT_MS=240000
# APIFY_POLL_INTERVAL_MS=5000
APIFY_TIKTOK_CRAWL_FALLBACK_ENABLED=1
APIFY_TIKTOK_VIDEO_FALLBACK_ENABLED=1
# 视频下载兜底额度：单账号每天最多 3 条，全服务器每天最多 25 条。
APIFY_TIKTOK_VIDEO_TENANT_DAILY_LIMIT=3
APIFY_TIKTOK_VIDEO_DAILY_LIMIT=25

# ── Instagram 采集：cookie(yt-dlp) 为主，Apify 兜底 ───────────────────────────
# IG 封了匿名访问，直链走 yt-dlp 需要登录态 cookie 文件（见下方 YT_DLP_COOKIE_FILES）；
# 关键词无公开搜索，走 Apify hashtag。yt-dlp 拿不到时统一回落 Apify。
# 视频下载兜底与 TikTok 共用同一份日额度（APIFY_TIKTOK_VIDEO_*_DAILY_LIMIT）。
APIFY_INSTAGRAM_ACTOR=apify/instagram-scraper
APIFY_INSTAGRAM_CRAWL_FALLBACK_ENABLED=1
APIFY_INSTAGRAM_VIDEO_FALLBACK_ENABLED=1
# yt-dlp 登录态 cookie（Netscape cookies.txt，逗号分隔多个）。IG/FB 直链免 Apify 时需要。
# 从已登录 IG 的浏览器用 cookies.txt 扩展导出后填绝对路径。
YT_DLP_COOKIE_FILES=

# ── Facebook 对标账号主页采集：yt-dlp/cookie 为主，Apify posts actor 兜底 ───────
# Facebook 关键词仍走公开视频搜索；账号主页推荐云端保留 Apify 兜底，actor 会只收视频帖、跳过图片帖。
APIFY_FACEBOOK_ACTOR=apify/facebook-posts-scraper
APIFY_FACEBOOK_CRAWL_FALLBACK_ENABLED=1

# Social account OAuth. Fill these only in local .env or server .env.production.
# Do not commit real OAuth client secrets to Git.
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
META_SOCIAL_APP_ID=
META_SOCIAL_APP_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
ADVANCED_MANUAL_CONNECT_ENABLED=false
