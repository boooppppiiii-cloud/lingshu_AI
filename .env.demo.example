PORT=8790
DEMO_MODE=true

# Demo limits
DEMO_TRIAL_DAYS=7
DEMO_DAILY_AI_CHAT_LIMIT=20
DEMO_DAILY_GENERATION_LIMIT=10
DEMO_DAILY_RENDER_LIMIT=3
# Optional. If set, registration requires this invite code.
DEMO_INVITE_CODE=

# PocketBase
PB_URL=http://localhost:8090
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=

# Subscription gate can stay false in demo because demo quotas handle trial limits.
SUBSCRIPTION_ENFORCED=false
RENDER_TOKEN_SECRET=change-me-demo-render-secret

# AI providers. Leave empty to use fallback/demo responses where available.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional Qwen/DashScope
OVERSEAS_LLM_BACKEND=
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=

# Optional storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
