PORT=8790
DEMO_MODE=true

# Demo limits
# Trial duration is fixed in code: 5 days.
DEMO_ALLOWED_ACCOUNTS=test1@example.com,test2@example.com
DEMO_DAILY_AI_CHAT_LIMIT=20
DEMO_DAILY_GENERATION_LIMIT=10
DEMO_DAILY_RENDER_LIMIT=3
DEMO_VIDEO_GENERATION_LIMIT=2
DEMO_DAILY_TOKEN_LIMIT=30000
DEMO_TOTAL_TOKEN_LIMIT=30000
# Optional. If set, registration requires this invite code.
DEMO_INVITE_CODE=

# PocketBase
PB_URL=http://localhost:8090
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=

# Subscription gate can stay false in demo because demo quotas handle trial limits.
SUBSCRIPTION_ENFORCED=false
RENDER_TOKEN_SECRET=change-me-demo-render-secret

# AI providers. Leave empty to use fallback/demo responses where available.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VIDEO_ENABLED=false
GEMINI_VIDEO_MODEL=veo-2.0-generate-001

# Seedance / ModelArk video generation. Keep disabled in public demo unless a
# real trial budget and quota policy are configured.
SEEDANCE_API_KEY=
SEEDANCE_VIDEO_ENABLED=false
SEEDANCE_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
SEEDANCE_MODEL=doubao-seedance-2-0-fast-260128

# Optional Qwen/DashScope
OVERSEAS_LLM_BACKEND=
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=

# Optional storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
