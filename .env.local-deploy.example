# 灵枢 AI 本地部署统一配置模板
# 复制为 ~/.config/lingshu-ai/.env.local 后填写；绝对不要提交真实值到 Git。

# ── 核心大模型 ──────────────────────────────────────────────────────────────
# 至少配置 Gemini 或 DashScope 其中一个；推荐以 Qwen 为默认、Gemini 做视觉能力。
OVERSEAS_LLM_BACKEND=qwen
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_TEXT_MODEL=qwen-plus
QWEN_VL_MODEL=qwen-vl-max

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VIDEO_ENABLED=false
# GEMINI_PROXY=http://127.0.0.1:7890

# ── 社媒采集 / Apify 兜底 ───────────────────────────────────────────────────
APIFY_TOKEN=
APIFY_TIKTOK_ACTOR=clockworks/tiktok-scraper
APIFY_INSTAGRAM_ACTOR=apify/instagram-scraper
APIFY_FACEBOOK_ACTOR=apify/facebook-posts-scraper
APIFY_TIKTOK_CRAWL_FALLBACK_ENABLED=1
APIFY_TIKTOK_VIDEO_FALLBACK_ENABLED=1
APIFY_INSTAGRAM_CRAWL_FALLBACK_ENABLED=1
APIFY_INSTAGRAM_VIDEO_FALLBACK_ENABLED=1
APIFY_FACEBOOK_CRAWL_FALLBACK_ENABLED=1
APIFY_TIMEOUT_MS=240000
APIFY_VIDEO_TIMEOUT_MS=240000

# 仅填写自有采集账号导出的 cookies.txt；不要分享个人浏览器 Cookie。
YT_DLP_COOKIE_FILES=

# ── 配音 / 音色克隆 ─────────────────────────────────────────────────────────
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io
MINIMAX_TTS_MODEL=speech-2.8-hd
# MINIMAX_GROUP_ID=

# ── 视频生成 ────────────────────────────────────────────────────────────────
SEEDANCE_API_KEY=
SEEDANCE_VIDEO_ENABLED=true
SEEDANCE_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
SEEDANCE_MODEL=doubao-seedance-2-0-fast-260128

# ── PocketBase ──────────────────────────────────────────────────────────────
PB_URL=http://127.0.0.1:8090
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=
PB_AUTO_START=false

# ── Cloudflare R2（不使用云素材存储时可留空）────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=overseas-assets
R2_PUBLIC_URL=

# ── 社媒发布 OAuth（仅需抓取时可留空）───────────────────────────────────────
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
META_SOCIAL_APP_ID=
META_SOCIAL_APP_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── 本地应用 ────────────────────────────────────────────────────────────────
PORT=8790
DEMO_MODE=true
SUBSCRIPTION_ENFORCED=false
LOCAL_ADMIN_EMAIL=admin@local.test
LOCAL_ADMIN_PASSWORD=
ADMIN_DASHBOARD_EMAILS=admin@local.test

# 以下签名密钥每台环境单独随机生成，不应多人共用。
RENDER_TOKEN_SECRET=
OAUTH_STATE_SECRET=
ASSET_ACCESS_SECRET=
SUPPORT_ACCESS_SECRET=
REGISTRATION_CREDENTIAL_KEY=
TENANT_PLATFORM_APP_KEY=
