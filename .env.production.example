# Copy this file to .env.production on the server and fill real values.

# Public domains. Point both DNS A records to your server IPv4.
APP_DOMAIN=lingshu.site
PB_DOMAIN=pb.lingshu.site
PUBLIC_BASE_URL=https://lingshu.site

# PocketBase version used by Dockerfile.pocketbase.
PB_VERSION=0.39.5

# PocketBase admin account. Create the same superuser in the PocketBase admin UI first.
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=change-me-to-a-strong-password

# Server port inside the app container.
PORT=8788

# Security.
RENDER_TOKEN_SECRET=change-me-to-a-long-random-secret
TENANT_PLATFORM_APP_KEY=generate-with-openssl-rand-base64-32
REGISTRATION_CREDENTIAL_KEY=generate-with-openssl-rand-base64-32
SUPPORT_ACCESS_SECRET=generate-with-openssl-rand-base64-32
SUBSCRIPTION_ENFORCED=false

# LLM backend. Configure at least one.
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Or use Qwen / DashScope.
# OVERSEAS_LLM_BACKEND=qwen
# DASHSCOPE_API_KEY=
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional video generation.
SEEDANCE_API_KEY=
SEEDANCE_VIDEO_ENABLED=false
SEEDANCE_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
SEEDANCE_MODEL=doubao-seedance-2-0-fast-260128

# Optional crawler / social publishing keys.
YOUTUBE_API_KEY=
APIFY_TOKEN=
# 本地 TikTok 采集优先；失败后使用 Apify 兜底。设为 0 可关闭对应兜底。
APIFY_TIKTOK_CRAWL_FALLBACK_ENABLED=1
APIFY_TIKTOK_VIDEO_FALLBACK_ENABLED=1
# 视频下载兜底额度：单账号每天最多 3 条，全服务器每天最多 25 条。
APIFY_TIKTOK_VIDEO_TENANT_DAILY_LIMIT=3
APIFY_TIKTOK_VIDEO_DAILY_LIMIT=25
R2_PUBLIC_URL=
R2_BACKUP_PREFIX=lingshu-backups
R2_BACKUP_LOCAL_RETENTION_DAYS=7

# Social account OAuth. Configure these once as the platform admin.
# Register these callback URLs in the corresponding developer consoles:
# https://lingshu.site/api/overseas/youtube/oauth/callback
# https://lingshu.site/api/overseas/social/oauth/instagram/callback
# https://lingshu.site/api/overseas/social/oauth/facebook/callback
# https://lingshu.site/api/overseas/social/oauth/tiktok/callback
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
META_SOCIAL_APP_ID=
META_SOCIAL_APP_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Keep manual token entry hidden from customers unless implementation staff need it.
ADVANCED_MANUAL_CONNECT_ENABLED=false
