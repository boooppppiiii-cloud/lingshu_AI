{
  "name": "overseas-marketing-agent",
  "version": "0.1.0",
  "description": "中国厂家出海营销 AI Agent 服务",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "NODE_USE_ENV_PROXY=1 tsx watch --exclude data server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production NODE_USE_ENV_PROXY=1 tsx server/index.ts",
    "setup:pb": "tsx scripts/setup-pb.ts",
    "migrate:tenant-business-data": "tsx scripts/migrate-tenant-business-data.ts",
    "migrate:production-data": "tsx scripts/migrate-production-data.ts",
    "backup:production-data": "bash scripts/backup-production-data.sh",
    "restore:production-data": "bash scripts/restore-production-data.sh",
    "demo:sync-accounts": "tsx scripts/sync-demo-accounts.ts",
    "import:trend-videos": "tsx scripts/import-trend-videos.ts",
    "worker:crawl": "NODE_USE_ENV_PROXY=1 tsx scripts/local-crawl-worker.ts",
    "demo:seed": "tsx scripts/demo-seed.ts",
    "demo:reset": "tsx scripts/demo-reset.ts",
    "test:outbound-guard": "tsx server/autonomy/outboundGuard.test.ts",
    "test:autonomy": "tsx server/autonomy/actionRules.test.ts",
    "test:knowledge-policy": "tsx server/knowledge/retrieve.test.ts",
    "test:strategy-policy": "tsx server/knowledge/strategyRetrieve.test.ts",
    "test:tenant-isolation": "tsx server/security/tenantIsolation.test.ts",
    "test:tenant-sync-smoke": "tsx scripts/verify-tenant-sync.ts",
    "test": "npm run test:outbound-guard && npm run test:autonomy && npm run test:knowledge-policy && npm run test:strategy-policy && npm run test:tenant-isolation",
    "desktop": "electron desktop/main.cjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1070.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^2.11.0",
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "axios": "^1.18.0",
    "compression": "^1.8.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.3.0",
    "form-data": "^4.0.6",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.20.0",
    "motion": "^12.40.0",
    "node-cron": "^4.4.1",
    "openai": "^6.39.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.0",
    "tailwindcss": "^4.3.1",
    "undici": "^8.5.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^33.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
